# Node Environment
NODE_ENV=development
PORT=3000

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=apostae
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# Redis
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL=300

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=8h

# Security
BCRYPT_ROUNDS=10
SESSION_TIMEOUT=1800000

# Logging
LOG_LEVEL=info
